        media_type = self._media["type"]
        if media_type == "photo":
            return "Images"
        elif media_type == "gif":
            return "Videos"
        elif media_type == "forced_skipped":
            return "Forced_skipped"
        else:
            return f"{media_type}s".capitalize()

    @property
