        # --- Parameters for SessionSleep objects---
        forbidden_sleeper: Optional[SessionSleep] = None,
        rate_limit_sleeper: Optional[SessionSleep] = None,
        # --- Parameters for the 429/504 Rate Limit Sleeper ---
