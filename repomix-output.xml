        "OFSC_TRUNCATION_DEFAULT", "True"
    ).lower() in ("true", "1")

    # MAX_COUNT_DEFAULT: Default maximum count for certain operations.
    # Default: 0 (no limit)
    config["MAX_COUNT_DEFAULT"] = int(os.getenv("OFSC_MAX_COUNT_DEFAULT", "0"))

