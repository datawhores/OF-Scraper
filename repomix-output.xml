async def get_lists():
    output = []
    page_count = 0
    async with manager.Manager.session.aget_subscription_session(
        sem_count=of_env.getattr("SUBSCRIPTION_SEMS"),
    ) as c:
        page_task = progress_updater.userlist.add_overall_task(
