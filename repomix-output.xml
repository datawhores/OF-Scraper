@contextlib.contextmanager
def lowstdout():
    if settings.get_settings().output_level in of_env.getattr("SUPRESS_OUTPUTS"):
        save_stdout = sys.stdout
        sys.stdout = open(os.devnull, "w")
        yield
        sys.stdout = save_stdout
    else:
